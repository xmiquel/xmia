+                "time": int(r[0]),
+                "open": float(r[1]),
+                "high": float(r[2]),
+                "low": float(r[3]),
+                "close": float(r[4]),
+                "tick_volume": int(r[5]),
+                "spread": int(r[6]),
+                "real_volume": int(r[7]),
+            }
+            for r in rates
+            if int(r[0]) < before
+        ]
